{
  "version": "3.6.0",
  "type": "media_renderer",
  "name": "Naim-Topping-Vintage Master",
  "description": "Gen 3 Multi-Protocol Driver: Naim WAV, Topping Stack, BM8000 Datalink",
  "developer": "Custom Audiophile Integration",
  "capabilities": [
    "transport_control",
    "now_playing_metadata",
    "media_browser",
    "media_search",
    "power_control",
    "volume_control"
  ],
  "parameters": [
    {
      "id": "itach_ip",
      "name": "iTach IP Address",
      "type": "string",
      "description": "Enter the IP of your Global Caché iTach (e.g., 192.168.77.XXX)",
      "required": true
    },
    {
      "id": "primary_core_path",
      "name": "Living Room Core Path",
      "type": "string",
      "description": "Enter the exact BLI resource path for the main broadcaster",
      "required": true
    },
    {
      "id": "party_zone_paths",
      "name": "Party Zone Paths",
      "type": "string",
      "description": "Enter comma-separated paths for the secondary zones",
      "required": false
    },
    {
      "id": "run_diag_on_boot",
      "name": "Run Diagnostics on Startup",
      "type": "boolean",
      "default": false
    },
    { "id": "p1_label", "name": "Preset 1 Name", "type": "string", "default": "P1" },
    { "id": "p2_label", "name": "Preset 2 Name", "type": "string", "default": "P2" }
  ],
  "resource_types": [
    {
      "id": "bo_playlist",
      "name": "B&O Playlist",
      "description": "Manual entry for B&O / Tidal playlist",
      "parameters": [
        { "id": "playlist_address", "type": "string", "name": "Tidal URL Address", "required": true }
      ],
      "commands": [
        { "id": "play_bo_playlist", "name": "Play Playlist" }
      ]
    }
  ],
  "resources": [
    { "id": "play", "name": "Play", "type": "button" },
    { "id": "pause", "name": "Pause", "type": "button" },
    { "id": "play_pause_toggle", "name": "Play/Pause Toggle", "type": "button" },
    { "id": "mute", "name": "Mute Toggle", "type": "button" },
    { "id": "next", "name": "Next Track", "type": "button" },
    { "id": "prev", "name": "Prev Track", "type": "button" },
    { "id": "search_fwd", "name": "Forward >>", "type": "button" },
    { "id": "search_rew", "name": "Rewind <<", "type": "button" },
    { "id": "step_fwd", "name": "Balance >", "type": "button" },
    { "id": "step_rev", "name": "Balance <", "type": "button" },
    { "id": "party_mode", "name": "House Party Mode", "type": "switch" },
    { "id": "bm8000_filter", "name": "BM8000 Filter", "type": "switch" },
    { "id": "d90_fir", "name": "D90 FIR Filter", "type": "button" },
    { "id": "d90_input_next", "name": "D90 Input >>", "type": "button" },
    { "id": "d90_input_prev", "name": "D90 Input <<", "type": "button" },
    { "id": "run_diagnostics", "name": "Run Diagnostics Now", "type": "button" },
    {
      "id": "source_selector",
      "name": "System Source",
      "type": "selector",
      "options": ["Naim Core", "B&O Streaming", "Beogram Vinyl", "Beocord Tape", "FM Radio"]
    },
    {
      "id": "a90_gain",
      "name": "A90 Gain",
      "type": "selector",
      "options": ["Low Gain", "High Gain"]
    },
    {
      "id": "a90_output",
      "name": "A90 Output Mode",
      "type": "selector",
      "options": ["PRE (Speakers)", "HPA (Headphones)", "HPA+PRE"]
    },
    {
      "id": "bm8000_presets",
      "name": "BM8000 Presets",
      "type": "selector",
      "options": ["P1", "P2", "P3", "P4", "P5", "P6", "P7", "P8", "P9", "P0"]
    }
  ],
  "states": [
    { "id": "TRACK_TITLE", "type": "string" },
    { "id": "TRACK_ARTIST", "type": "string" },
    { "id": "ALBUM_ART_URL", "type": "string" },
    { "id": "AUDIO_QUALITY", "type": "string" },
    { "id": "TRACK_PROGRESS", "type": "integer" },
    { "id": "TRACK_DURATION", "type": "integer" },
    { "id": "TRANSPORT_STATE", "type": "enum", "values": ["PLAYING", "PAUSED", "STOPPED", "BUFFERING"] },
    { "id": "ONLINE_STATUS", "type": "enum", "values": ["ONLINE", "OFFLINE"] },
    { "id": "VOLUME", "type": "integer", "min": 0, "max": 100 }
  ],
  "commands": [
    {
      "name": "NAIM_POWER",
      "description": "Discrete power control for the Uniti Core",
      "arguments": [
        { "name": "state", "type": "STRING", "description": "ON or STANDBY" }
      ]
    },
    {
      "name": "SHUFFLE",
      "description": "Toggle Naim Shuffle Mode",
      "arguments": [
        { "name": "mode", "type": "STRING", "description": "1 for ON, 0 for OFF" }
      ]
    },
    {
      "name": "REPEAT",
      "description": "Toggle Naim Repeat Mode",
      "arguments": [
        { "name": "mode", "type": "STRING", "description": "0=OFF, 1=ONE, 2=ALL" }
      ]
    }
  ]
}
