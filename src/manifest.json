{
  "version": "3.3.2",
  "type": "media_renderer",
  "name": "Naim-Topping-Vintage Master",
  "description": "Gen 3 Multi-Protocol Driver: Naim WAV, Topping Stack, and Full BM8000 Datalink with Micro-Step Tuning",
  "developer": "Custom Audiophile Integration",
  "capabilities": [
    "transport_control",
    "now_playing_metadata",
    "media_browser",
    "media_search",
    "power_control",
    "volume_control"
  ],
  "parameters": [
    {
      "id": "itach_ip",
      "name": "iTach IP Address",
      "type": "string",
      "description": "Enter the IP of your Global Caché iTach (e.g., 192.168.77.XXX)",
      "required": true
    },
    { "id": "p1_label", "name": "Preset 1 Name", "type": "string", "default": "P1" },
    { "id": "p2_label", "name": "Preset 2 Name", "type": "string", "default": "P2" },
    { "id": "p3_label", "name": "Preset 3 Name", "type": "string", "default": "P3" },
    { "id": "p4_label", "name": "Preset 4 Name", "type": "string", "default": "P4" },
    { "id": "p5_label", "name": "Preset 5 Name", "type": "string", "default": "P5" },
    { "id": "p6_label", "name": "Preset 6 Name", "type": "string", "default": "P6" },
    { "id": "p7_label", "name": "Preset 7 Name", "type": "string", "default": "P7" },
    { "id": "p8_label", "name": "Preset 8 Name", "type": "string", "default": "P8" },
    { "id": "p9_label", "name": "Preset 9 Name", "type": "string", "default": "P9" },
    { "id": "p0_label", "name": "Preset 0 Name", "type": "string", "default": "P0" }
  ],
  "resources": [
    { "id": "play", "name": "Play", "type": "button" },
    { "id": "pause", "name": "Pause", "type": "button" },
    { "id": "next", "name": "Next Track", "type": "button" },
    { "id": "prev", "name": "Prev Track", "type": "button" },
    
    { "id": "search_fwd", "name": "Auto Scan >>", "type": "button" },
    { "id": "search_rew", "name": "Auto Scan <<", "type": "button" },
    { "id": "step_fwd", "name": "Fine Tune >", "type": "button" },
    { "id": "step_rev", "name": "Fine Tune <", "type": "button" },
    
    { "id": "party_mode", "name": "House Party Mode", "type": "switch" },
    { "id": "bm8000_filter", "name": "BM8000 Filter", "type": "switch" },
    
    {
      "id": "source_selector",
      "name": "System Source",
      "type": "selector",
      "options": ["Naim Core", "B&O Streaming", "Beogram Vinyl", "Beocord Tape", "FM Radio"]
    },
    {
      "id": "a90_gain",
      "name": "A90 Gain",
      "type": "selector",
      "options": ["Low Gain", "High Gain"]
    },
    {
      "id": "a90_output",
      "name": "A90 Output Mode",
      "type": "selector",
      "options": ["PRE (Speakers)", "HPA (Headphones)", "HPA+PRE"]
    },
    {
      "id": "bm8000_presets",
      "name": "BM8000 Presets",
      "type": "selector",
      "options": ["P1", "P2", "P3", "P4", "P5", "P6", "P7", "P8", "P9", "P0"]
    }
  ],
  "states": [
    { "id": "TRACK_TITLE", "type": "string" },
    { "id": "TRACK_ARTIST", "type": "string" },
    { "id": "ALBUM_ART_URL", "type": "string" },
    { "id": "AUDIO_QUALITY", "type": "string" },
    { "id": "TRACK_PROGRESS", "type": "integer" },
    { "id": "TRACK_DURATION", "type": "integer" },
    { "id": "TRANSPORT_STATE", "type": "enum", "values": ["PLAYING", "PAUSED", "STOPPED"] },
    { "id": "ONLINE_STATUS", "type": "enum", "values": ["ONLINE", "OFFLINE"] },
    { "id": "VOLUME", "type": "integer", "min": 0, "max": 100 }
  ]
}
